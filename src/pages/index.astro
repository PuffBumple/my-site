---
import BaseLayout from '../layouts/BaseLayout.astro';

import Card from '../components/Card.astro';

const title = "What everything means";
const features = [
  "Home page = what you see right now :3",
  "about= stuff about me :3",
  "Blog = where I write about my thoughts, crushes, daily arson, and whatever else I want to talk about :3",
];
---

<BaseLayout title="Home">
  <h1>Welcome</h1>
  <h2>Content warnings:</h2>
</BaseLayout>

<Card title="GAY" description="I'm very gay and queer :3" />
<Card title="Depression" description="I'm very depressed and anxious. I might talk about self-harm and shit." />


<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <style>
      body {
        font-family: system-ui, sans-serif;
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem;
      }
      h1 { color: #7c3aed; }
      h2 { color: #5b21b6; }
    </style>
  </head>
  <body>
    <h1>{title}</h1>
    <p>Home page for all things me.</p>
    <ul>
      {features.map(f => <li>{f}</li>)}
    </ul>
  </body>
</html>