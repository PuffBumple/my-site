---
import Layout from '../layouts/Layout.astro';
import myAudio from '../assets/venus-suko.mp3';
---

<Layout title="About">
  <span class="eyebrow">✦ all about me :3</span>
  <h1>About <em>ME</em></h1>

  <div class="card">
    <h2>Basic shit</h2>
    <div class="info-list">
      <div class="info-row">Hiii :3</div>
      <div class="info-row">My name's <span class="hi">Willow</span></div>
      <div class="info-row">I'm not great at coding but I'm learning</div>
      <div class="info-row">I will never stop using ":3"</div>
      <div class="info-row">my favourite colour</div>
      <div class="info-row">my favourite song:<br><br>
        <audio controls>
          <source src={myAudio} type="audio/mpeg" />
          Your browser does not support the audio element.
        </audio></div>
</div>
    </div>

  <div class="card">
    <h2>My (very gay) Identity</h2>
    <div class="identity-grid">
      <div>
        <h3>Pronouns</h3>
        <p style="font-size: 0.77rem; color: var(--text-dim); margin-bottom: 0.55rem;">in order of preference</p>
        <div class="pronoun-tags">
          <span class="tag">fae/faer</span>
          <span class="tag">it/its</span>
          <span class="tag">she/her</span>
          <span class="tag">they/them</span>
        </div>
      </div>
      <div>
        <h3>Sexuality</h3>
        <ul class="sexuality-list">
          <li>aromantic</li>
          <li>panromantic</li>
          <li>asexual</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="card evil-card">
    <h2>gimmie your credit card information :3</h2>
    <p class="evil-header">totally safe and legit, promise :3</p>

    <div class="form-field">
      <label class="form-label">Cardholder Name</label>
      <input class="form-input" type="text" placeholder="your name here >:3" />
    </div>
    <div class="form-field">
      <label class="form-label">Card Number</label>
      <input class="form-input" type="text" placeholder="0000 0000 0000 0000" />
    </div>
    <div class="form-grid">
      <div class="form-field">
        <label class="form-label">Expiry Date</label>
        <input class="form-input" type="text" placeholder="MM / YY" />
      </div>
      <div class="form-field">
        <label class="form-label">Security Code</label>
        <input class="form-input" type="text" placeholder="• • •" />
      </div>
    </div>
    <button class="evil-btn" onclick="alert('hehehe >:3\n\n(i\'m kidding, i don\'t actually want your card info)')">
      Give it
    </button>
  </div>
</Layout>
