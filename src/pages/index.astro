---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <span class="eyebrow">✦ welcome to my corner :3</span>
  <h1>Welcome</h1>

  <div class="card">
    <h2>Content warnings</h2>
    <div class="cw-grid">
      <div class="cw-item">
        <span class="cw-emoji">🌈</span>
        <div>
          <span class="cw-label">GAY</span>
          <p class="cw-desc">I'm very gay and queer :3</p>
        </div>
      </div>
      <div class="cw-item">
        <span class="cw-emoji">🌧️</span>
        <div>
          <span class="cw-label">Depression</span>
          <p class="cw-desc">I'm very depressed and anxious. I might talk about self-harm and stuff.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <h2>What everything means</h2>
    <p style="font-size: 0.87rem; color: var(--text-dim); margin-top: 0.2rem;">Home page for all things me.</p>
    <ul class="site-list">
      <li><span class="page-name">Home</span> what you see right now :3</li>
      <li><span class="page-name">About</span> stuff about me :3</li>
      <li><span class="page-name">Blog</span> where I write about my thoughts, crushes, daily arson, and whatever else I want to talk about :3</li>
    </ul>
  </div>
</Layout>
