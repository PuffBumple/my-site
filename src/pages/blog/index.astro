---
import Layout from '../../layouts/Layout.astro';

const postModules = import.meta.glob('./*.md', { eager: true });
const posts = Object.entries(postModules).map(([path, mod]: [string, any]) => ({
  url: '/blog/' + path.replace('./', '').replace('.md', ''),
  frontmatter: mod.frontmatter,
}));

const parseDate = (value: string) => {
  const match = value.match(/^(\d{1,2})[-/](\d{1,2})[-/](\d{4})$/);
  if (!match) {
    return new Date(value).getTime();
  }

  const [, day, month, year] = match;
  return Date.UTC(Number(year), Number(month) - 1, Number(day));
};

posts.sort((a, b) => parseDate(b.frontmatter.date) - parseDate(a.frontmatter.date));
---

<Layout title="Blog">
  <span class="eyebrow">✦ brain dumps :3</span>
  <h1>Blog</h1>

  {posts.length === 0 ? (
    <div class="card">
      <div class="empty-state">
        <div class="empty-icon"></div>
        <h2>nothing here yet :3</h2>
        <p>thoughts, crushes, and daily arson coming soon</p>
      </div>
    </div>
  ) : (
    <div class="card">
      <ul class="post-list">
        {posts.map(post => (
          <li class="post-item">
            <p class="post-date">{post.frontmatter.date}</p>
            <a href={post.url} class="post-title">{post.frontmatter.title}</a>
          </li>
        ))}
      </ul>
    </div>
  )}
</Layout>