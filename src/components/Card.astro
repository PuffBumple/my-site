---
const { title, description } = Astro.props;
---

<div class="card">
  <h2>{title}</h2>
  <p>{description}</p>
</div>

<style>
  .card {
    border: 1px solid #eacfec;
    border-radius: 8px;
    padding: .5rem;
    margin-bottom: .5rem;
    {description} {
      color: #eacfec;
    }
  }
</style>